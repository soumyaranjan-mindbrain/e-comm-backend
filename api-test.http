# {
#   "success": true,
#   "count": 1,
#   "searchTerm": "NEW",
#   "data": [ { "id": 1, "name": "NEWUSER10", ... } ]
# }
#
# ❌ ERROR (400) — no search term:
# { "success": false, "message": "Search term is required. Please provide 'q' query parameter." }

###

### 10.5 Update Coupon
# ✏️  EDIT: Change @couponId and update fields as needed
# ✏️  ENSURE: @token is set
# ─────────────────────────────────────────────
PUT {{baseUrl}}/coupon-codes/{{couponId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "description": "Updated description",
  "validPrice": 1000,
  "issuedQnty": 200
}

# ✅ EXPECTED RESPONSE (200 OK):
# {
#   "success": true,
#   "message": "Coupon updated successfully",
#   "data": { "id": 1, "description": "Updated description", ... }
# }

