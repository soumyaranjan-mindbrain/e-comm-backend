### 10. COUPON CODES
### ════════════════════════════════════════════

@couponId = 1

### 10.1 Create Coupon
# ✏️  EDIT: Fill coupon details as needed
# Auth NOT required for creation
# ─────────────────────────────────────────────
POST {{baseUrl}}/coupon-codes
Content-Type: application/json

{
  "name": "NEWUSER10",
  "description": "10% discount for new users",
  "termsConditions": "Valid once per user",
  "validCategory": "Electronics",
  "validBrand": "Samsung",
  "validEdition": "2025",
  "validItem": "Mobile",
  "validPrice": 500,
  "validDate": "2026-12-31",
  "issuedQnty": 100,
  "userQnty": 1
}

# ✅ EXPECTED RESPONSE (201 Created):
# {
#   "success": true,
#   "message": "Coupon created successfully",
#   "data": {
#     "id": 1,
#     "name": "NEWUSER10",
#     "description": "10% discount for new users",
#     "validPrice": "500",
#     ...
#   }
# }
#
# ❌ ERROR (400) — name missing:
# { "success": false, "message": "coupon name required" }

###

### 10.2 Get All Coupons
# ✏️  ENSURE: @token is set
# ─────────────────────────────────────────────
GET {{baseUrl}}/coupon-codes
Authorization: Bearer {{token}}

# ✅ EXPECTED RESPONSE (200 OK):
# {
#   "success": true,
