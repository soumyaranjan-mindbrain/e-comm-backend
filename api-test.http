# 1. AUTHENTICATION
### Send OTP
POST {{baseUrl}}/auth/send-otp
Content-Type: application/json

{ "mobile": "9876543210" }

### Verify OTP
POST {{baseUrl}}/auth/verify-otp
Content-Type: application/json

{ "mobile": "9876543210", "otp": "111111" }


# 2. USER ADDRESSES (Protected)
### Get my addresses
GET {{baseUrl}}/user-addresses/me
Authorization: Bearer {{token}}

### Create new address
POST {{baseUrl}}/user-addresses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "address": "Flat 402, Sunshine Apartments, MG Road",
  "townCity": "Bangalore",
  "pincode": "560001",
  "receiversName": "Rahul Sharma",
  "receiversNumber": "9988776655",
  "saveAs": "Home"
}

### Get address by ID
GET {{baseUrl}}/user-addresses/11
Authorization: Bearer {{token}}

### Update address
PUT {{baseUrl}}/user-addresses/11
Authorization: Bearer {{token}}
Content-Type: application/json

{ "saveAs": "Work" }

### Delete address
DELETE {{baseUrl}}/user-addresses/11
Authorization: Bearer {{token}}


# 3. CATEGORIES
### List all active categories
GET {{baseUrl}}/categories

### Fuzzy and partial search
GET {{baseUrl}}/categories?q=ELECTORNICS


# 4. PRODUCT LIST & FILTERS
### Get all products
GET {{baseUrl}}/product-register?limit=20

### Get products by collection slug
GET {{baseUrl}}/product-register?slugs=new-arrivals

### Search products by name
GET {{baseUrl}}/product-register/search?q=shirt

### Filter by min and max price
GET {{baseUrl}}/product-register?minPrice=500&maxPrice=5000

### Filter by minimum rating
GET {{baseUrl}}/product-register?rating=4

### Filter by category ID
GET {{baseUrl}}/product-register?categoryId=61

### Combined filter search
GET {{baseUrl}}/product-register?q=shirt&minPrice=100&rating=3

### Get single product details
GET {{baseUrl}}/product-register/1