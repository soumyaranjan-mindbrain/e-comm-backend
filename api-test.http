  "receiversNumber": "9876543210",
  "saveAs": "Home"
}

###

# @name updateAddress
PUT {{baseUrl}}/user-addresses/1
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "address": "456 Updated Lane"
}

###

# @name deleteAddress
DELETE {{baseUrl}}/user-addresses/1
Authorization: Bearer {{authToken}}

###

