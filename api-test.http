### BM2MALL BACKEND - REST CLIENT TEST SUITE (v1.2.0)
### Base URL: http://localhost:3000/v1

@baseUrl = http://localhost:3000/v1
@contentType = application/json
@authToken = YOUR_JWT_TOKEN_HERE

############################################################
# 1. SYSTEM & HEALTH
############################################################

# @name healthCheck
GET {{baseUrl}}/health
Content-Type: {{contentType}}

###

############################################################
# 2. AUTHENTICATION MODULE
############################################################

# @name signup
POST {{baseUrl}}/auth/signup
Content-Type: {{contentType}}

{
  "fullName": "Test User",
  "mobile": "9876543210",
  "email": "test@example.com"
}

###

# @name sendOtp
POST {{baseUrl}}/auth/send-otp
Content-Type: {{contentType}}

{
  "mobile": "9876543210"
}

###

# @name verifyOtp
POST {{baseUrl}}/auth/verify-otp
Content-Type: {{contentType}}

{
  "mobile": "9876543210",
  "otp": "123456"
}

###

# @name refreshToken
POST {{baseUrl}}/auth/refresh-token
Content-Type: {{contentType}}

{
  "refreshToken": "YOUR_REFRESH_TOKEN_HERE"
}

###

# @name logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

############################################################
# 3. PRODUCT CATALOG
############################################################

# @name getAllProducts
GET {{baseUrl}}/products
Content-Type: {{contentType}}

###

# @name getFilteredProducts
# Query Params: q, minPrice, maxPrice, rating, categoryId, limit, cursor
GET {{baseUrl}}/products?q=shoe&minPrice=100&maxPrice=5000&rating=4&categoryId=1
Content-Type: {{contentType}}

###

# @name searchProductsFast
GET {{baseUrl}}/products/search?q=phone
Content-Type: {{contentType}}

###

# @name getProductById
GET {{baseUrl}}/products/1
Content-Type: {{contentType}}

###

# @name getProductRegister
# Supports ?slugs=new-arrivals or category slug
GET {{baseUrl}}/product-register?slugs=new-arrivals
Content-Type: {{contentType}}

###

# @name getProductRegisterById
GET {{baseUrl}}/product-register/1
Content-Type: {{contentType}}

###

############################################################
# 4. CATEGORIES
############################################################

# @name getAllCategories
GET {{baseUrl}}/categories
Content-Type: {{contentType}}

###

# @name getCategoryById
GET {{baseUrl}}/categories/1
Content-Type: {{contentType}}

###

############################################################
# 5. SHOPPING CART (Auth Required)
############################################################

# @name getCart
GET {{baseUrl}}/cart
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name addToCart
POST {{baseUrl}}/cart
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "ItemId": 1,
  "quantity": 2
}

###

# @name updateCartQuantity
PUT {{baseUrl}}/cart/1
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "quantity": 5
}

###

# @name removeFromCart
DELETE {{baseUrl}}/cart/1
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name clearCart
DELETE {{baseUrl}}/cart/clear/all
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

############################################################
# 6. ORDER MANAGEMENT (Auth Required)
############################################################

# @name placeOrder
POST {{baseUrl}}/orders
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "comId": 1,
  "items": [
    {
      "productId": 1,
      "qnty": 2,
      "rate": 150.50,
      "net_amount": 301.00
    }
  ],
  "total_amount": 301.00,
  "payment_mode": "CASH"
}

###

# @name getOrderDetails
GET {{baseUrl}}/orders/ORDER_ID_HERE
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name trackOrder
GET {{baseUrl}}/orders/ORDER_ID_HERE/track
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name updateOrderStatus
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/status
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "status": "SHIPPED",
  "updated_by": 1
}

###

# @name cancelOrder
PATCH {{baseUrl}}/orders/ORDER_ID_HERE/cancel
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "updated_by": 1
}

###

############################################################
# 7. ACCOUNT & PROFILE (Auth Required)
############################################################

# @name getMyProfile
GET {{baseUrl}}/profile/me
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

###

# @name updateProfile
PATCH {{baseUrl}}/profile/me
Authorization: Bearer {{authToken}}
# Note: Use Multipart/Form-Data in real client for photo upload
Content-Type: {{contentType}}

{
  "fullName": "Updated Test User",
  "email": "updated@example.com"
}

###

