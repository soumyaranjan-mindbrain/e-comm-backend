### ════════════════════════════════════════════
### 5. CART
### ════════════════════════════════════════════
# ⚠️  IMPORTANT — productId in Cart:
#     From Product Detail → data.productId = 5014 (NOT data.id = 15)
#     Use 5014 (or your real value) in ALL cart route bodies and URLs


### 5.1 Get Cart
# ✏️  ENSURE: @token is set
# ─────────────────────────────────────────────
GET {{baseUrl}}/cart
Authorization: Bearer {{token}}

# ✅ EXPECTED RESPONSE (200 OK) — cart has items:
# {
#   "success": true,
#   "count": 1,
#   "data": {
#     "items": [
#       {
#         "cartId": 1,
#         "productId": 5014,
#         "productName": "Tasty Bronze Chicken",
#         "productImage": null,
#         "quantity": 1,
#         "price": 969.88,
#         "itemTotal": 969.88
#       }
#     ],
#     "grandTotal": 969.88
#   }
# }
#
# ✅ EXPECTED RESPONSE — cart is empty:
# { "success": true, "count": 0, "data": { "items": [], "grandTotal": 0 } }

###

### 5.2 Add to Cart
# ✏️  EDIT: productId = data.productId from Product Detail (e.g. 5014)
# ✏️  EDIT: quantity = number of items to add
# ✏️  ENSURE: @token is set
# ─────────────────────────────────────────────
POST {{baseUrl}}/cart
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "productId": 5014,
  "quantity": 1
}

# ✅ EXPECTED RESPONSE (200 OK):
# {
#   "success": true,
#   "message": "Item added to cart successfully",
#   "data": {
#     "cartId": 1,
#     "ItemId": 5014,
#     "comId": 15,
#     "quantity": 1,
#     "isDeleted": false
#   }
# }
#
# ❌ ERROR (400) — missing productId or quantity:
# { "success": false, "message": "productId and quantity are required" }

###

### 5.3 Update Cart (Change Quantity)
# ✏️  EDIT: Replace 5014 in URL with productId from your cart items
# ✏️  EDIT: quantity = new quantity value
# ✏️  ENSURE: @token is set
# ─────────────────────────────────────────────
PUT {{baseUrl}}/cart/5014
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "quantity": 3
}

# ✅ EXPECTED RESPONSE (200 OK):
# {
#   "success": true,
#   "message": "Cart quantity updated successfully",
#   "data": {
#     "cartId": 1,
#     "ItemId": 5014,
#     "comId": 15,
#     "quantity": 3,
#     "isDeleted": false
#   }
# }
#
# ❌ ERROR (400) — item not in cart:
# { "success": false, "message": "Cart item not found" }

###

### 5.4 Remove from Cart (Single Item)
# ✏️  EDIT: Replace 5014 in URL with productId from your cart items
# ✏️  ENSURE: @token is set
# ─────────────────────────────────────────────
DELETE {{baseUrl}}/cart/5014
Authorization: Bearer {{token}}

# ✅ EXPECTED RESPONSE (200 OK):
# {
#   "success": true,
#   "message": "Item removed from cart successfully"
# }

###

### 5.5 Delete All Cart (Clear)
# ✏️  ENSURE: @token is set
# No body needed. Removes ALL items from cart.
# ─────────────────────────────────────────────
# ─────────────────────────────────────────────
DELETE {{baseUrl}}/cart/clear/all
Authorization: Bearer {{token}}

###


### ════════════════════════════════════════════
### 6. ORDERS
### ════════════════════════════════════════════

@orderId = 746202ad-0fad-4619-b31a-babc72316835

### 6.1 Create Order
# ✏️  ENSURE: @token is set
# ✏️  EDIT: Change total_amount and items to match your cart/needs
# ─────────────────────────────────────────────
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "payment_mode": "COD",
  "total_amount": 1500,
  "items": [
    {
      "productId": 5014,
      "qnty": 2,
      "rate": 750,
      "net_amount": 1500
    }
  ]
}

# ✅ EXPECTED RESPONSE (201 Created):
# Copy the order_id from response into @orderId above


### 6.2 Get Order Details
# ✏️  ENSURE: @token and @orderId are set
# ─────────────────────────────────────────────
GET {{baseUrl}}/orders/{{orderId}}
Authorization: Bearer {{token}}


### 6.3 Get All Orders
# ✏️  ENSURE: @token is set
# Optional query params: page, limit, status
# ─────────────────────────────────────────────
GET {{baseUrl}}/orders
Authorization: Bearer {{token}}


### 6.4 Track Order (Status History)
# ✏️  ENSURE: @token and @orderId are set
# ─────────────────────────────────────────────
GET {{baseUrl}}/orders/{{orderId}}/track
Authorization: Bearer {{token}}


### 6.5 Update Order Status
# ✏️  ENSURE: @token and @orderId are set
# ✏️  EDIT: Valid statuses: "PENDING", "CONFIRMED", "SHIPPED", "DELIVERED", "CANCELLED"
# ─────────────────────────────────────────────
PATCH {{baseUrl}}/orders/{{orderId}}/status
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "CONFIRMED",
  "updated_by": 1
}


### 6.6 Cancel Order
# ✏️  ENSURE: @token and @orderId are set
# ─────────────────────────────────────────────
PATCH {{baseUrl}}/orders/{{orderId}}/cancel
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "updated_by": 1
}


### ════════════════════════════════════════════
### 7. ORDER RETURNS
### ════════════════════════════════════════════

@returnId = 1

### 7.1 Create Return Request
# ✏️  ENSURE: @token and @orderId are set
# ─────────────────────────────────────────────
POST {{baseUrl}}/order-returns
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "productId": 5014,
  "comId": 15,
  "returnReason": "Product damaged during shipping",
  "pickupDate": "2026-03-01",
  "refundAmount": 750
}


### 7.2 Get All Return Requests
# ✏️  ENSURE: @token is set
# ─────────────────────────────────────────────
GET {{baseUrl}}/order-returns
Authorization: Bearer {{token}}


### 7.3 Get Return Request by ID
# ✏️  ENSURE: @token and @returnId are set
# ─────────────────────────────────────────────
GET {{baseUrl}}/order-returns/{{returnId}}
Authorization: Bearer {{token}}


### 7.4 Update Return Status (Admin)
# ✏️  ENSURE: @token and @returnId are set
# ✏️  EDIT: Valid statuses: "APPROVED", "REJECTED"
# ─────────────────────────────────────────────
PATCH {{baseUrl}}/order-returns/{{returnId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "status": "REJECTED"
}


