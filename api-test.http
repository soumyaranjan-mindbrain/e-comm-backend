# ==============================================================================
# 1. AUTHENTICATION & PROFILE
# ==============================================================================

### Signup User
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "fullName": "Test User",
  "mobile": "1546598563",
  "email": "testuser@example.com"
}

### Send OTP (Login)
POST {{baseUrl}}/auth/send-otp
Content-Type: application/json

{ "mobile": "9876543210" }

### Verify OTP (Get Access)
POST {{baseUrl}}/auth/verify-otp
Content-Type: application/json

{
  "mobile": "9876543210",
  "otp": "111111"
}

### Get My Profile
GET {{baseUrl}}/profile/me
Authorization: Bearer {{token}}

### Update Profile
PATCH {{baseUrl}}/profile/me
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fullName": "Updated Professional Name",
  "email": "updated@example.com"
}

### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{token}}


# ==============================================================================
# 2. PRODUCT CATALOG (SHOP)
# ==============================================================================

### List All Products (Paginated)
GET {{baseUrl}}/products?limit=20

### [IMPROVED] Search Products by Name
GET {{baseUrl}}/products?q=Chicken

### [IMPROVED] Filter by Price Range
GET {{baseUrl}}/products?minPrice=300&maxPrice=1500

### [IMPROVED] Filter by Category
GET {{baseUrl}}/products?categoryId=61

### [NEW] Get Single Product Details (Variants & Related)
# Includes detailed stock, sizes, colors, and related items
GET {{baseUrl}}/products/3

### [NEW] Get New Arrivals
GET {{baseUrl}}/products?slugs=new-arrivals


# ==============================================================================
# 3. CATEGORIES
# ==============================================================================

### List All Categories
GET {{baseUrl}}/categories

### Get Category Details
GET {{baseUrl}}/categories/61


# ==============================================================================
# 4. CUSTOMER DATA (PROTECTED)
# ==============================================================================

### Get Saved Addresses
GET {{baseUrl}}/user-addresses/me
Authorization: Bearer {{token}}

### Add New Address
POST {{baseUrl}}/user-addresses
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "address": "123 Business Park, Sector 62",
  "townCity": "Noida",
  "pincode": "201301",
  "receiversName": "Office Admin",
  "receiversNumber": "9876543210",
  "saveAs": "Work"
}

### Update Address
PUT {{baseUrl}}/user-addresses/2
Authorization: Bearer {{token}}
Content-Type: application/json

{ "saveAs": "Home" }


# ==============================================================================
# 5. OFFERS & RATINGS
# ==============================================================================

### List Available Coupons
GET {{baseUrl}}/coupon-codes

### Search Coupon
GET {{baseUrl}}/coupon-codes/search?name=SAVE10

### Get Product Reviews
GET {{baseUrl}}/product-ratings/product/3

### Post a Review
POST {{baseUrl}}/product-ratings
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "productId": 3,
  "givenRatings": 5,
  "message": "Excellent quality and fast delivery!"
}