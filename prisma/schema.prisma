generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Customer {
  id           Int                     @id @default(autoincrement())
  comId        Int?                    @map("com_id")
  custType     String?                 @map("cust_type") @db.VarChar(10)
  partyCode    String?                 @map("party_code") @db.VarChar(10)
  fullName     String?                 @map("full_name") @db.VarChar(140)
  alias        String?                 @db.VarChar(140)
  contactNo    String?                 @map("contact_no") @db.VarChar(100)
  whatsappNo   String?                 @map("whatsapp_no") @db.VarChar(500)
  emailId      String?                 @map("email_id") @db.VarChar(100)
  gstNumber    String?                 @map("gst_no") @db.VarChar(150)
  panNo        String?                 @map("pan_no") @db.VarChar(20)
  state        Int?                    @default(19)
  area         String?                 @db.VarChar(50)
  location     String?                 @db.VarChar(100)
  addressone   String?                 @db.VarChar(150)
  addrestwo    String?                 @db.VarChar(20)
  userid       String?                 @db.VarChar(50)
  password     String?                 @db.VarChar(50)
  autonoid     Int?                    @default(1)
  ret_autono   Int?                    @default(1)
  status       aa13_customer_db_status @default(ONE)
  insertDate   String?                 @map("insert_date") @db.VarChar(40)
  insertUser   String?                 @map("insert_user") @db.VarChar(120)
  updateDate   String?                 @map("update_date") @db.VarChar(40)
  updateUser   String?                 @map("update_user") @db.VarChar(120)
  otp          String?                 @db.VarChar(255)
  otpValidUpto DateTime?               @map("otp_valid_upto") @db.DateTime(0)
  refreshToken String?                 @map("refresh_token") @db.VarChar(255)
  indate       DateTime?               @default(now()) @db.DateTime(0)
  
  addresses UserAddress[]
  ratings   ProductRating[]

  @@index([id, custType, partyCode, fullName, alias, state], map: "id")
  @@map("aa13_customer_db")
}

model Category {
  id            Int                             @id @default(autoincrement())
  comId         Int?                            @map("com_id")
  catName       String?                         @map("cat_name") @db.VarChar(180)
  catCode       String                          @map("cat_code") @db.VarChar(100)
  catDesc       String?                         @map("cat_desc") @db.Text
  categoryImage String?                         @map("category_image") @db.VarChar(255)
  addToWebsite  aa4_category_db_add_to_website? @default(ZERO) @map("add_to_website")
  priority      Int?                            @default(0)
  slugs         String?                         @db.VarChar(255)
  disorder      Int
  status        aa4_category_db_status          @default(ONE)
  insertDate    String?                         @map("insert_date") @db.VarChar(40)
  insertUser    String?                         @map("insert_user") @db.VarChar(120)
  updateDate    String?                         @map("update_date") @db.VarChar(40)
  updateUser    String?                         @map("update_user") @db.VarChar(120)

  @@index([id, catName], map: "id")
  @@index([id, catName, catCode], map: "index_category_db")
  @@map("aa4_category_db")
}

model ProductRegister {
  id             Int                                 @id @default(autoincrement())
  comId          Int?                                @map("com_id")
  productId      Int?                                @unique(map: "product_id") @map("product_id")
  productName    String?                             @map("product_name") @db.VarChar(255)
  newProtype     String?                             @map("new_protype") @db.VarChar(100)
  displaySection String?                             @map("display_section") @db.VarChar(100)
  shdesc         String?                             @db.Text
  lgdesc         String?                             @db.LongText
  keyFeatures    String?                             @map("key_features") @db.LongText
  cancelReturns  String?                             @map("cancel_returns") @db.Text
  overview       String?                             @db.LongText
  proimg         String?                             @db.VarChar(255)
  isDisplay      x1_app_product_register_is_display? @default(ONE) @map("is_display")
  deliveryDays   Int?                                @map("delivery_days")
  ratings        Decimal?                            @db.Decimal(2, 1)
  createdAt      DateTime?                           @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt      DateTime?                           @updatedAt @map("updated_at") @db.DateTime(0)
  
  images         ProductImageRegister[]
  stockItems     ShopStockItem[]

  @@map("x1_app_product_register")
}

model ProductImageRegister {
  id         Int                                 @id @default(autoincrement())
  productId  Int?                                @map("product_id")
  proimgs    String?                             @db.VarChar(255)
  status     x2_app_product_img_register_status? @default(ONE)
  created_at DateTime?                           @default(now()) @db.Timestamp(0)
  updated_at DateTime?                           @db.DateTime(0)

  product    ProductRegister?                    @relation(fields: [productId], references: [productId])

  @@map("x2_app_product_img_register")
}

model ProductRating {
  id           Int       @id @default(autoincrement())
  productId    Int?      @map("product_id")
  totalRatings Int?      @map("total_ratings")
  givenRatings Int?      @map("given_ratings")
  message      String?   @db.Text
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.DateTime(0)
  createdBy    Int?      @map("created_by")
  updatedBy    Int?      @map("updated_by")

  customer     Customer? @relation(fields: [createdBy], references: [id])

  @@map("x3_app_product_ratings")
}

model UserAddress {
  id              Int       @id @default(autoincrement())
  userId          Int?      @map("user_id")
  address         String?   @db.Text
  townCity        String?   @map("town_city") @db.VarChar(100)
  pincode         String?   @db.VarChar(10)
  receiversName   String?   @map("receivers_name") @db.VarChar(150)
  receiversNumber String?   @map("receivers_number") @db.VarChar(15)
  saveAs          String?   @map("save_as") @db.VarChar(50)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime? @updatedAt @map("updated_at") @db.DateTime(0)
  createdBy       Int?      @map("created_by")
  updatedBy       Int?      @map("updated_by")

  customer        Customer? @relation(fields: [userId], references: [id])

  @@map("x4_app_user_addresses")
}

model ShopStockItem {
  id                  Int                            @id @default(autoincrement())
  barCode             String?                        @map("bar_code") @db.VarChar(100)
  stoctUpdateDate     DateTime?                      @map("stoct_update_date") @db.Date
  shopId              Int?                           @map("shop_id")
  partyId             Int?                           @map("praty_id")
  edition             String?                        @db.VarChar(100)
  itemId              Int?                           @map("item_id")
  itemName            String?                        @map("item_name") @db.VarChar(50)
  itemCode            String?                        @map("item_code") @db.VarChar(50)
  brandId             String?                        @map("brand_id") @db.VarChar(50)
  brandName           String?                        @map("brand_name") @db.VarChar(50)
  brandCode           String?                        @map("brand_code") @db.VarChar(50)
  design_id           Int?
  design_name         String?                        @db.VarChar(50)
  color_id            Int?
  color_name          String?                        @db.VarChar(50)
  fabric_id           Int?
  fabric_name         String?                        @db.VarChar(50)
  catId               Int?                           @map("cat_id")
  catName             String?                        @map("cat_name") @db.VarChar(50)
  unit_id             Int?
  unit_name           String?                        @db.VarChar(50)
  gstper              Int?
  pur_rate            Float?                         @db.Float
  mrpRate             String?                        @map("mrp_rate") @db.VarChar(20)
  saleRate            Float?                         @map("sale_rate") @db.Float
  markupamt           Float                          @default(0)
  entry_meter         Float?                         @default(0) @db.Float
  entry_qty           Float?                         @default(0) @db.Float
  entry_return_meter  Float?                         @default(0) @db.Float
  entry_return_qty    Float?                         @default(0) @db.Float
  issue_meter         Float?                         @default(0) @db.Float
  issue_qty           Float?                         @default(0) @db.Float
  issue_return_meter  Float?                         @default(0) @db.Float
  issue_return_qty    Float?                         @default(0) @db.Float
  transfer_return_qty Float?                         @default(0) @db.Float
  cur_meter           Float?                         @default(0) @db.Float
  curQty              Float?                         @default(0) @map("cur_qty") @db.Float
  status              caa1_shop_stock_item_db_status @default(ONE)
  item_remarks        String?                        @db.Text
  bill_comment        String?                        @db.Text
  indate              DateTime                       @db.Date
  insert_date         String?                        @db.VarChar(40)
  insert_user         String?                        @db.VarChar(120)
  update_date         String?                        @db.VarChar(40)
  update_user         String?                        @db.VarChar(120)

  product             ProductRegister?               @relation(fields: [itemId], references: [productId])

  @@index([barCode], map: "bar_code")
  @@index([id, barCode, shopId, partyId, itemId, brandId, design_id, color_id, fabric_id, catId, unit_id], map: "id")
  @@index([id, barCode, shopId], map: "index2")
  @@index([partyId], map: "praty_id")
  @@map("caa1_shop_stock_item_db")
}

model CouponCode {
  id              Int       @id @default(autoincrement())
  name            String?   @db.VarChar(100)
